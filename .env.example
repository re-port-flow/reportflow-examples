# Re:port Flow API 認証情報とサンプルのデザインID
# このファイルを .env にコピーして値を設定してください。
#   cp .env.example .env
# .env は秘密情報を含むためコミットしないでください（.gitignore 済み）。

# --- API キー ---------------------------------------------------------------
# API キー（管理画面のワークスペース詳細 →「API連携」タブで発行。形式: ak_...）
# エンドポイント（https://api.re-port-flow.com/v1）は固定のため設定不要です。
REPORTFLOW_API_KEY=ak_your_api_key_here

# --- 各サンプルのデザインID ------------------------------------------------
# 各テンプレートをワークスペースへ複製後に取得した「自分のデザインID」を設定します。
# デザインIDは以下でも取得できます:
#   curl -s "https://api.re-port-flow.com/v1/file/designs" -H "appkey: $REPORTFLOW_API_KEY"
# バージョンは複製直後は通常 1 です。

# 請求書 (examples/invoice)
INVOICE_DESIGN_ID=
INVOICE_DESIGN_VERSION=1

# 見積もり (examples/quotation)
QUOTATION_DESIGN_ID=
QUOTATION_DESIGN_VERSION=1

# Invoice / 英語版 (examples/invoice-en)
INVOICE_EN_DESIGN_ID=
INVOICE_EN_DESIGN_VERSION=1

# 労働者名簿 (examples/worker-roster)
WORKER_ROSTER_DESIGN_ID=
WORKER_ROSTER_DESIGN_VERSION=1

# 秘密保持誓約書 (examples/nda) ※このテンプレートは version 2
NDA_DESIGN_ID=
NDA_DESIGN_VERSION=2
